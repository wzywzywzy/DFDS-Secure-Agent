# Copy to .env and fill in. NEVER commit .env to git.
# The hackathon team's OpenRouter API key (received in Discord private channel).
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME

# Which Gemini model to use (the hackathon allowed list).
GEMINI_MODEL=google/gemini-2.5-flash

# Set to "true" to bypass real LLM calls during development / Demo without internet.
# The mock LLM returns plausible structured output for legit emails and refuses
# to extract anything from poison emails.
MOCK_LLM=true
